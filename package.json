{
  "name": "vivid-life-theme",
  "displayName": "Vivid Life Theme",
  "description": "A multi-flavor color scheme system for VS Code (Visual Studio Code). 4 flavors × 6 variants = 24 themes. WCAG AA verified.",
  "version": "0.1.0",
  "publisher": "vivid-life-theme",
  "license": "MIT",
  "author": {
    "name": "Michael van Laar",
    "email": "michael@van-laar.de"
  },
  "homepage": "https://github.com/vivid-life-theme/vivid-life-vs-code",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivid-life-theme/vivid-life-vs-code.git"
  },
  "bugs": {
    "url": "https://github.com/vivid-life-theme/vivid-life-vs-code/issues"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "theme",
    "color-theme",
    "dark-theme",
    "light-theme",
    "wcag",
    "accessibility",
    "vivid-life"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#171717",
    "theme": "dark"
  },
  "type": "module",
  "scripts": {
    "build": "node build.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepackage": "npm run build",
    "package": "vsce package"
  },
  "devDependencies": {
    "@vivid-life-theme/design-system": "^0.2.1",
    "@vscode/vsce": "^3.9.1",
    "prettier": "^3.8.3"
  },
  "contributes": {
