  "tokenColors": [
    {
      "name": "comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#737373"
      }
    },
    {
      "name": "keyword",
      "scope": [
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d8b4fe"
      }
    },
    {
      "name": "string",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#84cc16"
      }
    },
    {
      "name": "number",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#f97316"
      }
    },
    {
      "name": "function",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#93c5fd"
      }
    },
    {
      "name": "parameter",
