  "tokenColors": [
    {
      "name": "comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block"
      ],
      "settings": {
        "foreground": "#525252"
      }
    },
    {
      "name": "keyword",
      "scope": [
        "keyword.control",
        "keyword.other",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#7e22ce"
      }
    },
    {
      "name": "string",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#365314"
      }
    },
    {
      "name": "number",
      "scope": [
        "constant.numeric",
        "constant.language"
      ],
      "settings": {
        "foreground": "#c2410c"
      }
    },
    {
      "name": "function",
      "scope": [
        "entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "name": "parameter",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#7c2d12",
        "fontStyle": "italic"
      }
    },
    {
      "name": "type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#713f12"
      }
    },
    {
      "name": "constant",
      "scope": [
        "constant.other"
      ],
      "settings": {
        "foreground": "#c2410c"
      }
    },
    {
      "name": "tag",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#1d4ed8"
      }
    },
    {
      "name": "attr",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#4d7c0f"
      }
    },
    {
      "name": "regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#b91c1c"
      }
    },
    {
      "name": "punct",
      "scope": [
        "punctuation"
      ],
      "settings": {
        "foreground": "#404040"
      }
    },
    {
      "name": "variable",
      "scope": [
        "variable.other.readwrite",
        "variable.other"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "name": "property",
      "scope": [
        "variable.other.property",
        "variable.other.member",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#171717"
      }
    },
    {
      "name": "decorator",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator entity.name.function",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#1d4ed8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#7e22ce"
      }
    },
    {
      "name": "builtin",
